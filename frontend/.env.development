# Empty value -> api.ts falls back to relative '/api/v1', which goes through
# Vite's dev proxy (vite.config.ts) -> in-cluster ClawManager backend at the
# clawmanager-gateway ClusterIP.
#
# If you ever run the backend on the host again (port 9001 directly), set:
#   VITE_API_URL=http://localhost:9001/api/v1
VITE_API_URL=
